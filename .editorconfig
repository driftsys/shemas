# .editorconfig — whitespace SSOT
# Both dprint and editors read this file.
# markdownlint restates line_length (80) because it cannot read .editorconfig
# for MD013.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.json]
indent_style = space
indent_size = 2

[*.toml]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
max_line_length = 80
trim_trailing_whitespace = true

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://driftsys.github.io/schemas/markspec/deps/v1.json",
  "title": "MarkSpec Dependencies",
  "description": "Cross-project dependencies and optional reverse-dependency data.",
  "type": "object",
  "required": ["project", "dependencies"],
  "additionalProperties": false,
  "properties": {
    "generated": {
      "type": "string",
      "format": "date-time"
    },
    "project": {
      "type": "string"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "refs"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "purl": { "type": "string" },
          "url": { "type": "string" },
          "refs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["from", "to"],
              "additionalProperties": false,
              "properties": {
                "from": { "type": "string" },
                "to": { "type": "string" },
                "kind": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "dependants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "refs"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "purl": { "type": "string" },
          "url": { "type": "string" },
          "refs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["from", "to"],
              "additionalProperties": false,
              "properties": {
                "from": { "type": "string" },
                "to": { "type": "string" },
                "kind": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
